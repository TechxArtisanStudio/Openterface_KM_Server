# Copy this file to .env and fill in your values.
# .env is git-ignored – never commit your real token.

# GitHub Personal Access Token (needs `repo` and `workflow` scopes)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Target repository  (owner/repo)
GITHUB_REPO=your-org/Openterface_KM_Server

# Workflow file name or numeric ID to trigger  (e.g. build.yml)
GITHUB_WORKFLOW=start-server.yml

# The branch/tag/ref to run the workflow on
GITHUB_REF=main
